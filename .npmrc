# For GitLab Package Registry, uncomment and configure:
# @temporalui:registry=https://gitlab.com/api/v4/projects/YOUR_PROJECT_ID/packages/npm/

# For npmjs.org (default for public packages):
# No configuration needed - @temporalui/* packages will be published to npmjs.org

# Use npmjs.org for all packages by default
registry=https://registry.npmjs.org/
