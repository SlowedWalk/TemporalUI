{
  "name": "@temporalui/react",
  "version": "0.1.0",
  "type": "module",
  "description": "React adapter for TemporalUI",
  "repository": {
    "type": "git",
    "url": "git+https://gitlab.com/idetoratojo1/temporalui.git"
  },
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc && tsc --emitDeclarationOnly",
    "dev": "tsc --watch"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@temporalui/core": "^0.1.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "react": "^18.3.0",
    "typescript": "^5.0.0"
  }
}
