{
  "name": "@temporalui/vue",
  "version": "0.1.0",
  "type": "module",
  "description": "Vue 3 adapter for TemporalUI",
  "repository": "https://gitlab.com/idetoratojo1/temporalui.git",
  "license": "MIT",
  "main": "./dist/index.js",
